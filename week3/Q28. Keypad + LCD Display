#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <Keypad.h>

// ---------------- LCD ----------------
LiquidCrystal_I2C lcd(0x27, 16, 2);

// ---------------- Keypad ----------------
const byte ROWS = 4;
const byte COLS = 4;

char keys[ROWS][COLS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};

byte rowPins[ROWS] = {9, 8, 7, 6};
byte colPins[COLS] = {5, 4, 3, 2};

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

// ---------------- Components ----------------
const int greenLED = 13;
const int redLED = 10;
const int buzzer = 11;

// ---------------- Password ----------------
String correctPIN = "1234";
String enteredPIN = "";

int wrongAttempts = 0;
bool locked = false;
unsigned long lockStartTime = 0;

void setup() {
  pinMode(greenLED, OUTPUT);
  pinMode(redLED, OUTPUT);
  pinMode(buzzer, OUTPUT);

  digitalWrite(greenLED, LOW);
  digitalWrite(redLED, LOW);

  lcd.init();
  lcd.backlight();

  lcd.setCursor(0, 0);
  lcd.print("ENTER PIN:");
  lcd.setCursor(0, 1);
}

void loop() {

  // Lock for 10 seconds after 3 wrong attempts
  if (locked) {
    if (millis() - lockStartTime >= 10000) {
      locked = false;
      wrongAttempts = 0;

      lcd.clear();
      lcd.print("ENTER PIN:");
      lcd.setCursor(0, 1);
    }
    return;
  }

  char key = keypad.getKey();

  if (key) {

    // Accept only numbers
    if (key >= '0' && key <= '9') {

      enteredPIN += key;
      lcd.print("*");
      tone(buzzer, 1200, 80);

      // Check when 4 digits entered
      if (enteredPIN.length() == 4) {

        delay(300);

        if (enteredPIN == correctPIN) {

          lcd.clear();
          lcd.print("ACCESS");
          lcd.setCursor(0, 1);
          lcd.print("GRANTED");

          digitalWrite(greenLED, HIGH);
          digitalWrite(redLED, LOW);

          tone(buzzer, 2000, 300);

          delay(2000);

          digitalWrite(greenLED, LOW);

          wrongAttempts = 0;
        }
        else {

          lcd.clear();
          lcd.print("ACCESS");
          lcd.setCursor(0, 1);
          lcd.print("DENIED");

          digitalWrite(redLED, HIGH);

          tone(buzzer, 500);
          delay(1000);
          noTone(buzzer);

          digitalWrite(redLED, LOW);

          wrongAttempts++;

          if (wrongAttempts >= 3) {

            locked = true;
            lockStartTime = millis();

            lcd.clear();
            lcd.print("SYSTEM LOCKED");
            lcd.setCursor(0, 1);
            lcd.print("WAIT 10 SEC");

            enteredPIN = "";
            return;
          }
        }

        // Reset for next attempt
        enteredPIN = "";

        lcd.clear();
        lcd.print("ENTER PIN:");
        lcd.setCursor(0, 1);
      }
    }

    // Clear PIN if '*' is pressed
    else if (key == '*') {
      enteredPIN = "";
      lcd.clear();
      lcd.print("ENTER PIN:");
      lcd.setCursor(0, 1);
    }

    // '#' can be ignored or used for future features
  }
}
