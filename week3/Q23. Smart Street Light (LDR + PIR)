const int LDR_PIN = A0;
const int PIR_PIN = 2;
const int LED_PIN = 9;   

const int LDR_THRESHOLD = 500;   

unsigned long motionTime = 0;

void setup()
{
  pinMode(PIR_PIN, INPUT);
  pinMode(LED_PIN, OUTPUT);

  Serial.begin(9600);
}

void loop()
{
  int ldrValue = analogRead(LDR_PIN);
  int motion = digitalRead(PIR_PIN);

  // Current time from Arduino uptime
  unsigned long seconds = millis() / 1000;
  int hh = (seconds / 3600) % 24;
  int mm = (seconds % 3600) / 60;
  int ss = seconds % 60;

  // DAYTIME
  if (ldrValue > LDR_THRESHOLD)
  {
    analogWrite(LED_PIN, 0);

    printTime(hh, mm, ss);
    Serial.println(" EVENT: Daylight - LED OFF");

    delay(1000);
    return;
  }

  // NIGHT MODE
  if (motion == HIGH)
  {
    motionTime = millis();

    analogWrite(LED_PIN, 255);

    printTime(hh, mm, ss);
    Serial.println(" EVENT: Motion Detected - LED Full Brightness");
  }

  // Keep LED ON for 30 seconds after motion
  if (millis() - motionTime < 30000)
  {
    analogWrite(LED_PIN, 255);
  }
  else
  {
    // Dim to 20%
    analogWrite(LED_PIN, 51);

    printTime(hh, mm, ss);
    Serial.println(" EVENT: No Motion - LED Dim (20%)");
  }

  delay(500);
}


void printTime(int h, int m, int s)
{
  Serial.print("[");

  if (h < 10) Serial.print("0");
  Serial.print(h);
  Serial.print(":");

  if (m < 10) Serial.print("0");
  Serial.print(m);
  Serial.print(":");

  if (s < 10) Serial.print("0");
  Serial.print(s);

  Serial.print("]");
}
