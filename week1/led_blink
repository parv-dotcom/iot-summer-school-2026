/*
  Author      : Parv Agrawal
  Date        : 01 July 2026
  Project     : LED Blink Speed Control using Potentiometer
  Description : Reads the potentiometer value from analog pin A0
                and controls the LED blink speed. As the
                potentiometer is rotated, the LED blinks
                faster or slower accordingly.
*/

int ledPin = 13;
int potPin = A0;

void setup() {
  pinMode(ledPin, OUTPUT);
  Serial.begin(9600);
}

void loop() {
  int potValue = analogRead(potPin);
  int blinkDelay = map(potValue, 0, 1023, 100, 1000);

  Serial.print("Potentiometer: ");
  Serial.print(potValue);
  Serial.print("   Blink Delay: ");
  Serial.print(blinkDelay);
  Serial.println(" ms");

  digitalWrite(ledPin, HIGH);
  delay(blinkDelay);

  digitalWrite(ledPin, LOW);
  delay(blinkDelay);
}
